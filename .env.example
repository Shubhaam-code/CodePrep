# ==================================================
# BACKEND ENVIRONMENT VARIABLES (.env in backend/)
# ==================================================

# MongoDB Connection String (Atlas or Local)
# Example: mongodb://localhost:27017/codeprep
# Example: mongodb+srv://username:password@cluster0.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/codeprep

# JWT Secret key for authentication tokens
JWT_SECRET=your_super_secret_key_here

# Port for Express server to listen on (Default: 5000)
PORT=5000

# Base URL for github raw data files (e.g. for fetching questions list)
GITHUB_RAW_BASE_URL=https://raw.githubusercontent.com/krishnadey30/LeetCode-Questions-CompanyWise/master


# ==================================================
# FRONTEND ENVIRONMENT VARIABLES (.env in frontend/)
# ==================================================

# Base URL of the backend API
# Example: http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
