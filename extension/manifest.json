{
  "manifest_version": 3,
  "name": "LeetCode Tracker Companion",
  "version": "1.0.0",
  "description": "Companion extension for LeetCode Company Tracker. Detects active problems and extracts metadata.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.leetcode.com/*",
    "https://api.codeprep.com/*",
    "https://codeprep.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://*.leetcode.com/problems/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageBridge.js"],
      "matches": [
        "https://leetcode.com/*",
        "https://*.leetcode.com/*"
      ]
    }
  ]
}
